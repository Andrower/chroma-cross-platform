{
  "name": "chroma-cross-electron-client",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "description": "Desktop locked client shell for Chroma Cross",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.chroma.cross.client",
    "productName": "Chroma Cross Client",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "server",
        "filter": [
          "chroma-control-server.js",
          "chroma-cross-screen.html",
          "chroma-launch.html",
          "node-windows/**"
        ]
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
