.DS_Store

# Generated archives and release artifacts
*.zip
*.exe
*.dmg
*.pkg
*.msi
*.apk

# Dependency folders
node_modules/
.pnpm-store/

# Electron build output
dist/
out/
release/

# Bundled runtimes are too large for a normal GitHub repo.
node-macos/
node-windows/

# Android/Gradle generated files
.idea/
.gradle/
build/
app/build/
local.properties

# Temporary duplicated working copies
work/

# Runtime/user data generated by the chroma server
outputs/chroma-presets.json
chroma-presets.json

# Keep source packages, ignore generated package copies when they only contain binaries.
outputs/chroma-cross-platform-package/mac/node-macos/
outputs/chroma-cross-platform-package/win/node-windows/
outputs/chroma-desktop-server/node-macos/
outputs/chroma-windows-portable-server/node-windows/
